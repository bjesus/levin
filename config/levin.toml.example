# Levin Configuration File
# =========================
# Copy this to ~/.config/levin/levin.toml and customize
#
# Most settings have sensible defaults. Only paths.watch_directory,
# paths.data_directory, and disk.min_free are required.
#
# WebTorrent support: ENABLED
# Levin can seed to both traditional BitTorrent clients and web browsers!
# For torrents to work with WebTorrent, they must have WebSocket trackers
# (wss://tracker.example.com) in addition to regular trackers.

# ---------------------------------------------------------------------------
# REQUIRED: Path Settings
# ---------------------------------------------------------------------------
[paths]
# Directory to watch for .torrent files
watch_directory = "~/.config/levin/torrents"

# Directory to store downloaded data
data_directory = "~/.cache/levin/data"

# Directory for state files (pid, log, socket, session, stats)
# Default: $XDG_STATE_HOME/levin/ or ~/.local/state/levin/
# state_directory = "~/.local/state/levin"

# ---------------------------------------------------------------------------
# REQUIRED: Disk Management
# ---------------------------------------------------------------------------
[disk]
# Minimum free space that must remain on disk (supports human-readable format)
# Examples: "1gb", "10gb", "500mb", "1tb"
min_free = "10gb"

# OPTIONAL: Minimum free space as percentage of total disk (0.05 = 5%)
# The effective minimum is max(min_free, total_disk * min_free_percentage)
# Default: 0.05 (5%)
# min_free_percentage = 0.05

# OPTIONAL: Maximum storage Levin can use (supports human-readable format)
# Examples: "100gb", "500gb", "1tb"
# Default: 0 (unlimited - only constrained by min_free)
# max_storage = "100gb"

# ---------------------------------------------------------------------------
# OPTIONAL: Daemon Settings (all have defaults)
# ---------------------------------------------------------------------------
[daemon]
# Log level: "trace", "debug", "info", "warn", "error", "critical"
# Default: "info"
# log_level = "info"

# Whether to run when on battery power
# Default: false (pause seeding when on battery, resume when plugged in)
# run_on_battery = false

# How often to check disk usage and rebalance storage (in seconds)
# Default: 60
# disk_check_interval_seconds = 60

# ---------------------------------------------------------------------------
# OPTIONAL: Bandwidth Limits (0 = unlimited)
# ---------------------------------------------------------------------------
[limits]
# Maximum download rate in KB/s (0 = unlimited)
# max_download_rate_kbps = 0

# Maximum upload rate in KB/s (0 = unlimited)
# max_upload_rate_kbps = 0

# ---------------------------------------------------------------------------
# OPTIONAL: WebTorrent Settings
# ---------------------------------------------------------------------------
[webtorrent]
# STUN server for WebRTC NAT traversal (ICE)
# Default: "stun.l.google.com:19302" (Google's public STUN server)
# Other options:
#   - stun:stun.l.google.com:19302 (Google)
#   - stun:stun1.l.google.com:19302 (Google backup)
#   - stun:stun.stunprotocol.org:3478 (STUN Protocol)
# stun_server = "stun.l.google.com:19302"

# ---------------------------------------------------------------------------
# Hardcoded Settings (for reference, cannot be changed in config)
# ---------------------------------------------------------------------------
# Network:
#   listen_port = 6881
#   enable_dht = true
#   enable_lsd = true
#   enable_upnp = true
#   enable_natpmp = true
#
# Torrents:
#   max_connections_per_torrent = 50
#   max_upload_slots_per_torrent = 8
#   max_total_connections = 200
#   max_active_downloads = unlimited (-1)
#   max_active_seeds = unlimited (-1)
#   max_active_torrents = unlimited (-1)
#
# Intervals:
#   seeder_update_interval = 60 minutes
#   watch_scan_interval = 30 seconds
#   statistics_save_interval = 5 minutes
#
# Derived paths (from state_directory):
#   pid_file = <state_directory>/levin.pid
#   log_file = <state_directory>/levin.log
#   control_socket = <state_directory>/levin.sock
#   session_state = <state_directory>/session.state
#   statistics_file = <state_directory>/statistics.json
